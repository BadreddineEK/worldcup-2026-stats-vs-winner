# ─────────────────────────────────────────────────────────────
# Copiez ce fichier en .streamlit/secrets.toml (NON versionné)
# et collez votre clé gratuite API-Football.
#
# 1. Créez un compte sur https://www.api-football.com/
# 2. Récupérez votre clé dans le Dashboard (onglet "API Keys").
# 3. Collez-la ci-dessous.
#
# En local  : ce fichier .streamlit/secrets.toml
# Sur le Cloud : Settings ▸ Secrets de l'app Streamlit (même contenu)
# ─────────────────────────────────────────────────────────────
API_FOOTBALL_KEY = "collez_votre_cle_ici"
